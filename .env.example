# ================================
# AURION COMMERCE - ENVIRONMENT VARIABLES
# ================================
# Copy this file to .env and fill in real values
# NEVER commit .env to Git

# ===== SERVER =====
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000
CLIENT_URL=http://localhost:5173
STOREFRONT_URL=http://localhost:3000

# ===== DATABASE =====
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/aurion-commerce

# ===== REDIS (for cache and job queues) =====
REDIS_URL=redis://localhost:6379

# ===== JWT AUTHENTICATION =====
# Generate strong random strings (at least 64 chars each)
JWT_ACCESS_SECRET=replace_with_random_64_char_string_here
JWT_REFRESH_SECRET=replace_with_another_random_64_char_string_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ===== CLOUDINARY (image storage) =====
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===== STRIPE (payments) =====
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_secret_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# ===== RESEND (transactional emails) =====
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=noreply@aurioncommerce.com

# ===== ALGOLIA (product search) - Phase 2 =====
ALGOLIA_APP_ID=your_app_id
ALGOLIA_API_KEY=your_api_key
ALGOLIA_INDEX_NAME=aurion_products

# ===== PLATFORM SETTINGS =====
PLATFORM_NAME=Aurion Commerce
PLATFORM_URL=https://aurioncommerce.com
ADMIN_EMAIL=admin@auriontech.com